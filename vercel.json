{
  "rewrites": [
    { "source": "/style", "destination": "/index.html" },
    { "source": "/chi-siamo", "destination": "/index.html" },
    { "source": "/listino", "destination": "/index.html" },
    { "source": "/contatti", "destination": "/index.html" },
    { "source": "/ritual", "destination": "/index.html" },
    { "source": "/ritual/listino", "destination": "/index.html" },
    { "source": "/ritual/contatti", "destination": "/index.html" },
    { "source": "/with-you", "destination": "/index.html" },
    { "source": "/with-you/storia", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(webp|jpg|jpeg|png|gif|svg|ico|mp4|woff|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ]
}
